# Copy to `.env` and fill in. Never commit `.env`.

# Required: OpenAI API key, used for question generation, report writing, and Whisper STT.
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override default model names.
GPT_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

# Optional: community feature (면접 후기). Without these the community tab
# shows a setup guide instead of the feed. See DEPLOY.md → "Supabase 설정".
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
